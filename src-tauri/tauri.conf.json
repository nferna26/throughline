{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Throughline",
  "version": "0.3.0",
  "identifier": "com.throughline.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Throughline",
        "width": 960,
        "height": 720,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["throughline"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/nferna26/throughline/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQxNkEyMERCQjI5NTA3RTQKUldUa0I1V3kyeUJxUVk1c0NRY1RmajFvTHJyanROb2dVZ3RSMW9DQ0l3Zy9QRjhNN1pNMDZXQTcK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "hardenedRuntime": true
    }
  }
}
